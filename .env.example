# FormulationOS Environment Configuration

# =============================================================================
# LLM API Keys (Workflow Planner)
# =============================================================================

# MiniMax API Key (recommended)
# Get your key from: https://platform.minimaxi.com
MINIMAX_API_KEY=sk-cp-YOUR-API-KEY-HERE

# OpenAI API Key (alternative)
# OPENAI_API_KEY=sk-YOUR-OPENAI-KEY-HERE

# =============================================================================
# Real Tool Integration (Optional)
# =============================================================================

# Enable real tools instead of mock
# USE_REAL_FORMULATION_TOOLS=false

# PreformulationAI Configuration
# PREFORMULATION_AI_BASE_URL=http://localhost:8000
# PREFORMULATION_AI_TOKEN=your-bearer-token

# FormulationAI Configuration
# FORMULATION_AI_BASE_URL=http://localhost:8001
# FORMULATION_AI_TOKEN=your-bearer-token
